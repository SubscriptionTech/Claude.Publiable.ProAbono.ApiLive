{
  "responses": {
    "200": {
      "description": "Invoice object",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "Id": {
                "type": "integer"
              },
              "IdCustomer": {
                "type": "integer"
              },
              "IdSegment": {
                "type": "integer"
              },
              "ReferenceCustomer": {
                "type": "string"
              },
              "ReferenceSegment": {
                "type": "string"
              },
              "FullNumber": {
                "type": "string",
                "nullable": true,
                "description": "Absent on Draft invoices"
              },
              "Currency": {
                "type": "string"
              },
              "AmountSubtotal": {
                "type": "integer",
                "description": "Subtotal amount in cents"
              },
              "AmountTotal": {
                "type": "integer",
                "description": "Total amount in cents"
              },
              "Status": {
                "type": "string",
                "enum": [
                  "Draft",
                  "Due",
                  "Paid",
                  "Problem",
                  "Void",
                  "Uncollectible"
                ],
                "description": "High-level functional state (StatusInvoice)"
              },
              "StateInvoice": {
                "type": "string",
                "enum": [
                  "Draft",
                  "DraftCharging",
                  "DueAuto",
                  "DueOffline",
                  "DueToProcess",
                  "DuePending",
                  "Paid",
                  "PaidRefunded",
                  "ProblemAuto",
                  "ProblemOverdue",
                  "ProblemDisputed",
                  "Void",
                  "Uncollectible"
                ],
                "description": "Granular technical state (StateInvoice)"
              },
              "TypePayment": {
                "type": "string",
                "enum": [
                  "Free",
                  "ExternalCheck",
                  "ExternalCash",
                  "ExternalBank",
                  "ExternalOther",
                  "Card",
                  "DirectDebit"
                ],
                "description": "Payment method (TypePayment)"
              },
              "DateIssue": {
                "type": "string",
                "format": "date-time",
                "nullable": true
              },
              "DateUpdate": {
                "type": "string",
                "format": "date-time",
                "nullable": true,
                "description": "Date of last update (ISO 8601)"
              },
              "DatePayment": {
                "type": "string",
                "format": "date-time",
                "nullable": true
              },
              "DatePaymentScheduled": {
                "type": "string",
                "format": "date-time",
                "nullable": true,
                "description": "Date the automated payment is scheduled for (ISO 8601). Only present when StateInvoice is DueAuto."
              },
              "DatePaymentLimit": {
                "type": "string",
                "format": "date-time",
                "nullable": true
              },
              "NoteLocalized": {
                "type": "string",
                "nullable": true,
                "description": "Note printed at the bottom of the invoice PDF"
              },
              "Links": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "rel": {
                      "type": "string",
                      "description": "Relationship type (e.g. \"self\", \"insite-home\")"
                    },
                    "href": {
                      "type": "string",
                      "description": "URL path to the related resource"
                    },
                    "query": {
                      "type": "string",
                      "description": "Encrypted query parameter (used for portal links)"
                    }
                  },
                  "title": "Link"
                }
              }
            },
            "title": "Invoice"
          },
          "examples": {
            "offline payment": {
              "summary": "Due invoice with offline payment",
              "value": {
                "Id": 3736352,
                "IdSegment": 7,
                "IdCustomer": 233700,
                "ReferenceSegment": "demo-eur",
                "ReferenceCustomer": "cust-42",
                "FullNumber": "S-7.00001673",
                "Status": "Due",
                "StateInvoice": "DueOffline",
                "DateIssue": "2026-05-19T08:28:27.92Z",
                "DateUpdate": "2026-05-19T08:28:27.92Z",
                "DatePayment": "2026-05-19T08:28:27.92Z",
                "DatePaymentLimit": "2026-06-17T08:28:27.84Z",
                "TypePayment": "ExternalCash",
                "AmountSubtotal": 10,
                "AmountTotal": 10,
                "Currency": "EUR",
                "NoteLocalized": "PO.123456 - Thank you for your trust.",
                "Links": [
                  {
                    "rel": "insite-related-invoice",
                    "href": "https://demo-eur.proabono.com/portal-inv-pdf/<crypted-query-arg>",
                    "type": "application/pdf"
                  },
                  {
                    "rel": "insite-home",
                    "href": "https://demo-eur.proabono.com/portal-auth/<crypted-query-arg>"
                  },
                  {
                    "rel": "insite-collection-invoice",
                    "query": "<encrypted-query>"
                  }
                ]
              }
            },
            "payment failed": {
              "summary": "Problem invoice (payment failed)",
              "value": {
                "Id": 3736352,
                "IdSegment": 7,
                "IdCustomer": 233700,
                "ReferenceSegment": "demo-eur",
                "ReferenceCustomer": "cust-42",
                "FullNumber": "S-7.00001673",
                "Status": "Problem",
                "StateInvoice": "ProblemAuto",
                "DateIssue": "2026-05-19T08:28:27.92Z",
                "DateUpdate": "2026-05-19T08:28:27.92Z",
                "DatePayment": "2026-05-19T08:28:27.92Z",
                "DatePaymentLimit": "2026-06-17T08:28:27.84Z",
                "TypePayment": "Undefined",
                "AmountSubtotal": 10,
                "AmountTotal": 10,
                "Currency": "EUR",
                "Links": [
                  {
                    "rel": "insite-related-invoice",
                    "href": "https://demo-eur.proabono.com/portal-inv-pdf/<crypted-query-arg>",
                    "type": "application/pdf"
                  },
                  {
                    "rel": "insite-home",
                    "href": "https://demo-eur.proabono.com/portal-auth/<crypted-query-arg>"
                  },
                  {
                    "rel": "insite-charge",
                    "query": "<encrypted-query>"
                  },
                  {
                    "rel": "insite-collection-invoice",
                    "query": "<encrypted-query>"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "401": {
      "description": "Missing or invalid credentials",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "Code": {
                "type": "string"
              },
              "Message": {
                "type": "string"
              },
              "Exception": {
                "type": "string",
                "description": "Only present on some 500 errors"
              },
              "Target": {
                "type": "string",
                "description": "Identifies the field or resource at fault"
              }
            },
            "title": "Error"
          }
        }
      }
    },
    "404": {
      "description": "Resource not found",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "Code": {
                "type": "string"
              },
              "Message": {
                "type": "string"
              },
              "Exception": {
                "type": "string",
                "description": "Only present on some 500 errors"
              },
              "Target": {
                "type": "string",
                "description": "Identifies the field or resource at fault"
              }
            },
            "title": "Error"
          }
        }
      }
    }
  }
}